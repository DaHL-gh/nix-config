font-family = "Iosevka Term"
font-family-bold = "Iosevka Term Medium"
font-family-italic = "Iosevka Term Light Oblique"
font-family-bold-italic = "Iosevka Term Medium Oblique"

font-size = 11

cursor-style = bar
cursor-style-blink = true
shell-integration-features = no-cursor

background-opacity = 0.7

confirm-close-surface = false
